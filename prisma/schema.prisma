// ASAS FOR EDUCATION - Database Schema
// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. USERS & AUTHENTICATION
// ==========================================

enum UserRole {
  ADMIN
  APPLICATION
  CONSULTANT
  SUB_AGENT
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole
  phone     String?
  avatar    String?
  isActive  Boolean  @default(true)
  lastSeenLeads DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedLeads Lead[]    @relation("ConsultantLeads")
  students      Student[] @relation("ConsultantStudents")
  announcements Announcement[]
  blogPosts     Blog[]

  @@map("users")
}

// ==========================================
// 2. LEADS (from website forms)
// ==========================================

enum LeadStatus {
  NEW
  QUALIFYING
  QUALIFIED
  APPOINTMENT
  DEAL
  NOT_INTERESTED
}

model Lead {
  id             String     @id @default(cuid())
  firstName      String
  lastName       String
  email          String
  phone          String
  city           String
  educationLevel String

  transcript     String?
  cv             String?
  diploma        String?
  passport       String?

  status         LeadStatus @default(NEW)
  sourceName     String     @default("Site Web")

  sessionType    String?

  universityName  String?
  departmentName  String?
  language        String?
  level           String?

  sourceId       String?
  consultantId   String?
  consultant     User?      @relation("ConsultantLeads", fields: [consultantId], references: [id])

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("leads")
}

// ==========================================
// 3. STUDENTS
// ==========================================

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Student {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  gender          Gender
  dateOfBirth     DateTime
  passportNumber  String
  citizenship     String
  email           String
  phone           String

  guardianName    String
  guardianEmail   String

  transcript      String?
  passportFile    String?
  diploma         String?
  languageProof   String?
  cv              String?
  motivationLetter String?
  photo         String?
  additionalDocs  String[]

  acceptance      String?
  status          String   @default("EN_ATTENTE")
  desiredProgramId String?
  desiredProgram   Program? @relation("DesiredProgram", fields: [desiredProgramId], references: [id])

  consultantId    String?
  consultant      User?     @relation("ConsultantStudents", fields: [consultantId], references: [id])

  notes           StudentNote[]
  applications    StudentApplication[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("students")
}

model StudentNote {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("student_notes")
}

model StudentApplication {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  programId String
  program   Program  @relation(fields: [programId], references: [id])
  status    String   @default("APPLIED") // APPLIED, RECEIVED, OFFER_LETTER, PAID, FINAL_ADMISSION
  offerLetter String?
  finalAdmission String?
  isUpdated Boolean @default(false)
  isNewPaid Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("student_applications")
}

// ==========================================
// 4. COUNTRIES, UNIVERSITIES & PROGRAMS
// ==========================================

model Country {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  flag      String?
  photo     String?
  cities    City[]
  createdAt DateTime @default(now())

  @@map("countries")
}

model City {
  id           String       @id @default(cuid())
  name         String
  countryId    String
  country      Country      @relation(fields: [countryId], references: [id], onDelete: Cascade)
  universities University[]
  createdAt    DateTime     @default(now())

  @@unique([name, countryId])
  @@map("cities")
}

model University {
  id          String    @id @default(cuid())
  name        String
  logo        String?
  photo       String?
  description String?
  website     String?
  cityId      String
  city        City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  programs    Program[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("universities")
}

model Program {
  id             String   @id @default(cuid())
  name           String
  department     String
  field          String?
  degree         String
  language       String
  duration       Int
  pricePerYear   Float?
  currency       String   @default("USD")
  description    String?
  image          String?

  universityId   String
  university     University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  applications   StudentApplication[]
  desiredByStudents Student[] @relation("DesiredProgram")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("programs")
}

// ==========================================
// 5. BLOG & CONTENT
// ==========================================

enum BlogTag {
  DESTINATION
  UNIVERSITY
  GENERAL
  SCHOLARSHIP
  TIPS
}

model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  coverImage  String?
  tags        BlogTag[]
  isPublished Boolean  @default(false)
  views       Int       @default(0)

  authorId    String
  author      User     @relation(fields: [authorId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blogs")
}

// ==========================================
// 6. ANNOUNCEMENTS
// ==========================================

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  isActive  Boolean  @default(true)

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

// ==========================================
// 7. SOURCES (tracking campaigns)
// ==========================================

model Source {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  platform    String
  influencer  String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("sources")
}
